# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase (public — safe for client-side use)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase (server-only — NEVER expose to client or commit)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# API (optional)
NEXT_PUBLIC_API_URL=/api

# Stitch MCP (local dev only — use .cursor/mcp.json or shell env, do not commit)
STITCH_API_KEY=your-stitch-api-key-here
