# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase (public — safe for client-side use)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase (server-only — NEVER expose to client or commit)
# Required for email/password sign-up (creates confirmed users without sending emails)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google OAuth is configured in the Supabase dashboard (not in this repo).
# Enable Google provider at: Authentication → Providers → Google

# API (optional)
NEXT_PUBLIC_API_URL=/api

# Grants.gov Simpler API (server-only)
SIMPLER_GRANTS_API_KEY=your-simpler-grants-api-key-here
