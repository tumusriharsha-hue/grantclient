# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase (public client configuration)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key

# Supabase (server-only - never expose this key to client code or commit it)
# Optional for admin maintenance scripts such as scripts/seed-grants.mjs
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google OAuth is configured in the Supabase dashboard (not in this repo).
# Enable Google provider at: Authentication -> Providers -> Google

# API (optional)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Local/testing only: requires Supabase Anonymous Sign-Ins to be enabled.
NEXT_PUBLIC_ENABLE_GUEST_SIGN_IN=true

# Grants.gov Simpler API (server-only)
SIMPLER_GRANTS_API_KEY=your_simpler_grants_api_key

# NVIDIA NIM (server-only)
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=
NVIDIA_NIM_TIMEOUT_MS=25000
NVIDIA_NIM_MAX_RETRIES=2
AI_PROVIDER=nvidia
