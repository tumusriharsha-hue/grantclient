# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# IDE / editor
.cursor/

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local agent/tooling state
/.agents/
/.codex/
/.turbo/
/.cache/
/tmp/
/supabase/.temp/

# test artifacts
/playwright-report/
/test-results/

# stitch exports (generated during design sync)
/stitch-export*/
/stitch-tools.json
/stitch-*.json
/.stitch-mcp/
